<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol always="true">10000</defaultcontrol>
	<include>dialogeffect</include>
	<depth>DepthOSD</depth>
	<onunload>ClearProperty(PlayerInfoDialogFocus,Home)</onunload>
	<coordinates>
		<left>0</left>
		<top>0</top>
	</coordinates>
	<controls>
		<control type="group">
			<depth>DepthOSD+</depth>
			<control type="image">
				<description>media info background image</description>
				<left>-30</left>
				<top>350r</top>
				<width>1980</width>
				<height>350</height>
				<texture>black-back.png</texture>
			</control>

			<control type="grouplist" id="10000">
				<top>403r</top>
				<include>HomeSubMenuCommonValues</include>
				<control type="image">
					<width>53</width>
					<height>53</height>
					<texture colordiffuse="B3FFFFFF" border="0,0,0,3" flipy="true" flipx="true">HomeSubEnd.png</texture>
				</control>
				
				<control type="button" id="10001">
					<height>53</height>
					<width>270</width>
					<textwidth>240</textwidth>
					<align>center</align>
					<aligny>center</aligny>
					<font>font12</font>
					<textcolor>grey2</textcolor>
					<focusedcolor>white</focusedcolor>
					<scroll>true</scroll>
					<texturefocus border="5">HomeSubFO.png</texturefocus>
					<texturenofocus colordiffuse="B3FFFFFF" border="5">HomeSubNF.png</texturenofocus>
					<pulseonselect>false</pulseonselect>
					<label>$LOCALIZE[31310]</label>
					<visible>VideoPlayer.Content(livetv)</visible>
					<onleft>10000</onleft>
					<onfocus>SetProperty(PlayerInfoDialogFocus,10001,Home)</onfocus>
				</control>
				
				<control type="button" id="10002">
					<height>53</height>
					<width>270</width>
					<textwidth>240</textwidth>
					<align>center</align>
					<aligny>center</aligny>
					<font>font12</font>
					<textcolor>grey2</textcolor>
					<focusedcolor>white</focusedcolor>
					<scroll>true</scroll>
					<texturefocus border="5">HomeSubFO.png</texturefocus>
					<texturenofocus colordiffuse="B3FFFFFF" border="5">HomeSubNF.png</texturenofocus>
					<pulseonselect>false</pulseonselect>
					<label>$LOCALIZE[31311]</label>
					<onleft condition="!VideoPlayer.Content(livetv)">10000</onleft>
					<onfocus>SetProperty(PlayerInfoDialogFocus,10002,Home)</onfocus>
				</control>
				
				<control type="button" id="10003">
					<height>53</height>
					<width>270</width>
					<textwidth>240</textwidth>
					<align>center</align>
					<aligny>center</aligny>
					<font>font12</font>
					<textcolor>grey2</textcolor>
					<focusedcolor>white</focusedcolor>
					<scroll>true</scroll>
					<texturefocus border="5">HomeSubFO.png</texturefocus>
					<texturenofocus colordiffuse="B3FFFFFF" border="5">HomeSubNF.png</texturenofocus>
					<pulseonselect>false</pulseonselect>
					<label>$LOCALIZE[31312]</label>
					<onfocus>SetProperty(PlayerInfoDialogFocus,10003,Home)</onfocus>
				</control>
				
				<control type="button" id="10004">
					<height>53</height>
					<width>270</width>
					<textwidth>240</textwidth>
					<align>center</align>
					<aligny>center</aligny>
					<font>font12</font>
					<textcolor>grey2</textcolor>
					<focusedcolor>white</focusedcolor>
					<scroll>true</scroll>
					<texturefocus border="5">HomeSubFO.png</texturefocus>
					<texturenofocus colordiffuse="B3FFFFFF" border="5">HomeSubNF.png</texturenofocus>
					<pulseonselect>false</pulseonselect>
					<label>$LOCALIZE[31313]</label>
					<onright condition="String.Contains(Player.Process(amlogic.vs10.mode),SDR) | [!String.IsEqual(Player.Process(video.dovi.has.config),1) + !String.IsEqual(Player.Process(video.dovi.has.header),1) + !String.IsEqual(Player.Process(video.hdr.has.cll),1) + !String.IsEqual(Player.Process(video.hdr.has.mdcv),1)]">10000</onright>
					<onfocus>SetProperty(PlayerInfoDialogFocus,10004,Home)</onfocus>
				</control>
				
				<control type="button" id="10005">
					<height>53</height>
					<width>270</width>
					<textwidth>240</textwidth>
					<align>center</align>
					<aligny>center</aligny>
					<font>font12</font>
					<textcolor>grey2</textcolor>
					<focusedcolor>white</focusedcolor>
					<scroll>true</scroll>
					<texturefocus border="5">HomeSubFO.png</texturefocus>
					<texturenofocus colordiffuse="B3FFFFFF" border="5">HomeSubNF.png</texturenofocus>
					<pulseonselect>false</pulseonselect>
					<label>HDR</label>
					<visible>!String.Contains(Player.Process(amlogic.vs10.mode),SDR)</visible>
					<visible>String.IsEqual(Player.Process(video.dovi.has.config),1) | String.IsEqual(Player.Process(video.dovi.has.header),1) | String.IsEqual(Player.Process(video.hdr.has.cll),1) | String.IsEqual(Player.Process(video.hdr.has.mdcv),1)</visible>
					<onright>10000</onright>
					<onfocus>SetProperty(PlayerInfoDialogFocus,10005,Home)</onfocus>
				</control>
				
				<control type="image">
					<width>53</width>
					<height>53</height>
					<texture colordiffuse="B3FFFFFF" border="0,0,0,3" flipy="true">HomeSubEnd.png</texture>
				</control>
			</control>

			<!-- ============================================================ -->
			<!-- PVR TAB (10001)                                               -->
			<!-- ============================================================ -->

			<control type="grouplist">
				<description>PVR - Left column</description>
				<left>50</left>
				<top>340r</top>
				<visible>String.IsEqual(Window(Home).Property(PlayerInfoDialogFocus),10001)</visible>
				<control type="label">
					<width>880</width>
					<height>38</height>
					<label>$LOCALIZE[19005]</label>
					<font>font13_title</font>
					<textcolor>blue</textcolor>
				</control>
				<control type="label">
					<width>880</width>
					<height>38</height>
					<label>[COLOR grey2]$LOCALIZE[19099]: [/COLOR]$INFO[PVR.ActStreamServiceName]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
				<control type="label">
					<width>880</width>
					<height>38</height>
					<label>[COLOR grey2]$LOCALIZE[19101]: [/COLOR]$INFO[PVR.ActStreamProviderName]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
				<control type="label">
					<width>880</width>
					<height>38</height>
					<label>[COLOR grey2]$LOCALIZE[19012]: [/COLOR]$INFO[PVR.ActStreamClient]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
				<control type="label">
					<width>880</width>
					<height>38</height>
					<label>[COLOR grey2]$LOCALIZE[19006]: [/COLOR]$INFO[PVR.ActStreamDevice]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
				<control type="label">
					<width>880</width>
					<height>38</height>
					<label>[COLOR grey2]$LOCALIZE[19007]: [/COLOR]$INFO[PVR.ActStreamStatus]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
				<control type="label">
					<width>880</width>
					<height>38</height>
					<label>[COLOR grey2]$LOCALIZE[19015]: [/COLOR]$INFO[PVR.ActStreamEncryptionName]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
			</control>

			<control type="grouplist">
				<description>PVR - Right column</description>
				<left>960</left>
				<top>340r</top>
				<visible>String.IsEqual(Window(Home).Property(PlayerInfoDialogFocus),10001)</visible>
				<usecontrolcoords>true</usecontrolcoords>
				<control type="label">
					<width>880</width>
					<height>38</height>
					<label>$LOCALIZE[31332]</label>
					<font>font13_title</font>
					<textcolor>blue</textcolor>
				</control>
				<control type="label">
					<width>880</width>
					<height>38</height>
					<label>[COLOR grey2]$LOCALIZE[19010]: [/COLOR]$INFO[PVR.ActStreamBER]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
				<control type="label">
					<width>880</width>
					<height>38</height>
					<label>[COLOR grey2]$LOCALIZE[19011]: [/COLOR]$INFO[PVR.ActStreamUNC]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
				<control type="label">
					<width>880</width>
					<height>38</height>
					<label>[COLOR grey2]$LOCALIZE[19100]: [/COLOR]$INFO[PVR.ActStreamMux]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
				<control type="label">
					<width>880</width>
					<height>38</height>
					<label>[COLOR grey2]$LOCALIZE[19008]: [/COLOR]$INFO[PVR.ActStreamSignal]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
				<control type="progress">
					<top>0</top>
					<left>0</left>
					<width>880</width>
					<height>18</height>
					<info>PVR.ActStreamProgrSignal</info>
				</control>
				<control type="label">
					<width>880</width>
					<height>38</height>
					<label>[COLOR grey2]$LOCALIZE[19009]: [/COLOR]$INFO[PVR.ActStreamSNR]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
				<control type="progress">
					<top>0</top>
					<left>0</left>
					<width>880</width>
					<height>21</height>
					<info>PVR.ActStreamProgrSNR</info>
				</control>
			</control>

			<!-- ============================================================ -->
			<!-- PLAYER TAB (10002) - Left: Video                             -->
			<!-- Note: NO $VAR[name, before, after] 3-arg forms used here.    -->
			<!-- All conditional wrapping done via visibility-split labels.    -->
			<!-- ============================================================ -->

			<control type="grouplist">
				<description>Player - Video column</description>
				<left>50</left>
				<top>340r</top>
				<visible>String.IsEqual(Window(Home).Property(PlayerInfoDialogFocus),10002)</visible>
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>$LOCALIZE[31007]</label>
					<font>font13_title</font>
					<textcolor>blue</textcolor>
				</control>
				<!-- Video: WxH@fps (aspect) -->
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>[COLOR grey2]Video: [/COLOR]$INFO[Player.Process(video.width.raw)]x$INFO[Player.Process(video.height.raw)]$INFO[Player.Process(videoscantype)] @ $INFO[Player.Process(videofps)] fps $INFO[VideoPlayer.VideoAspect,[COLOR grey2](,:1)[/COLOR]]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
				<!-- codec | resolution | bit depth -->
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>[COLOR grey2]- codec: [/COLOR]$VAR[VideoCodecPlayVar] $VAR[|] $INFO[VideoPlayer.VideoResolution]$VAR[VideoResolutionTypePlayVar, ] $VAR[|] $VAR[VideoBitDepthVar,,-bit]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo</visible>
				</control>
				<!-- HDR type: SDR (non-AV1) -->
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>[COLOR grey2]- type: [/COLOR]$INFO[Player.Process(video.source.hdr.type)]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + !String.IsEqual(VideoPlayer.VideoCodec,av1) + String.IsEqual(Player.Process(video.source.hdr.type.raw),0)</visible>
				</control>
				<!-- HDR type: HDR, no additional, no dual track (non-AV1) -->
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>[COLOR grey2]- type: [/COLOR]$INFO[Player.Process(video.source.hdr.type)]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + !String.IsEqual(VideoPlayer.VideoCodec,av1) + !String.IsEqual(Player.Process(video.source.hdr.type.raw),0) + String.IsEqual(Player.Process(video.source.additional.hdr.type.raw),0) + String.IsEmpty($VAR[DualTrackVar])</visible>
				</control>
				<!-- HDR type: HDR, no additional, WITH dual track (non-AV1) -->
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>[COLOR grey2]- type: [/COLOR]$INFO[Player.Process(video.source.hdr.type)] [COLOR grey2]($VAR[DualTrackVar])[/COLOR]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + !String.IsEqual(VideoPlayer.VideoCodec,av1) + !String.IsEqual(Player.Process(video.source.hdr.type.raw),0) + String.IsEqual(Player.Process(video.source.additional.hdr.type.raw),0) + !String.IsEmpty($VAR[DualTrackVar])</visible>
				</control>
				<!-- HDR type: HDR + additional, no dual track (non-AV1) -->
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>[COLOR grey2]- type: [/COLOR]$INFO[Player.Process(video.source.hdr.type)] $VAR[|] [COLOR grey2]$INFO[Player.Process(video.source.additional.hdr.type)][/COLOR]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + !String.IsEqual(VideoPlayer.VideoCodec,av1) + !String.IsEqual(Player.Process(video.source.hdr.type.raw),0) + !String.IsEqual(Player.Process(video.source.additional.hdr.type.raw),0) + String.IsEmpty($VAR[DualTrackVar])</visible>
				</control>
				<!-- HDR type: HDR + additional + dual track (non-AV1) -->
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>[COLOR grey2]- type: [/COLOR]$INFO[Player.Process(video.source.hdr.type)] [COLOR grey2]($VAR[DualTrackVar])[/COLOR] $VAR[|] [COLOR grey2]$INFO[Player.Process(video.source.additional.hdr.type)] ($VAR[DualTrackAddVar])[/COLOR]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + !String.IsEqual(VideoPlayer.VideoCodec,av1) + !String.IsEqual(Player.Process(video.source.hdr.type.raw),0) + !String.IsEqual(Player.Process(video.source.additional.hdr.type.raw),0) + !String.IsEmpty($VAR[DualTrackVar])</visible>
				</control>
				<!-- HDR type: AV1 -->
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>[COLOR grey2]- type: [/COLOR]$VAR[HDRcodectypeVar]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + String.IsEqual(VideoPlayer.VideoCodec,av1)</visible>
				</control>
				<!-- Color range | primaries -->
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>[COLOR grey2]- color: [/COLOR]$VAR[ColorRangeVar] $VAR[|] $VAR[ColorPrimariesVar]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo</visible>
				</control>
				<!-- Decoder | deinterlace
				     VideoHWDecoder always returns HW or SW - shown in parens directly in label.
				     No 3-arg VAR needed. -->
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>[COLOR grey2]- dec|deint: [/COLOR]$INFO[Player.Process(videodecoder),[UPPERCASE],[/UPPERCASE]] ($VAR[VideoHWDecoder]) $VAR[|] [CAPITALIZE]$INFO[Player.Process(deintmethod)][/CAPITALIZE]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
				<!-- Output pixel format: no DV tunnel -->
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>[COLOR grey2]- output: [/COLOR]$INFO[Player.Process(amlogic.pixformat)]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + !Integer.IsEqual(Player.Process(amlogic.vs10.mode.raw),1)</visible>
				</control>
				<!-- Output pixel format: with DV tunnel indicator -->
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>[COLOR grey2]- output: [/COLOR]$INFO[Player.Process(amlogic.pixformat)] [COLOR grey2](DV Tunnel)[/COLOR]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + Integer.IsEqual(Player.Process(amlogic.vs10.mode.raw),1)</visible>
				</control>
				<!-- Video bitrate -->
				<control type="label">
					<width>630</width>
					<height>38</height>
					<label>[COLOR grey2]- bitrate: [/COLOR]$INFO[Player.Process(video.live.mibit.rate),, Mb/s] $INFO[VideoPlayer.VideoMibitRate,[COLOR grey2](, Mb/s)[/COLOR]]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>

			</control>

			<!-- ============================================================ -->
			<!-- PLAYER TAB (10002) - Middle: Audio + Subtitle                -->
			<!-- ============================================================ -->

			<control type="grouplist">
				<description>Player - Audio + Subtitle column</description>
				<left>720</left>
				<top>340r</top>
				<visible>String.IsEqual(Window(Home).Property(PlayerInfoDialogFocus),10002)</visible>
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>$LOCALIZE[31013]</label>
					<font>font13_title</font>
					<textcolor>blue</textcolor>
				</control>
				<!-- Audio codec + channels.
				     ObjectAudioPlayVar now has colour embedded in variable values. -->
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>[COLOR grey2]Audio: [/COLOR]$VAR[AudioCodecPlayVar]$VAR[AudioChannelsPlayVar, ]$VAR[ObjectAudioPlayVar, ]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>!String.IsEmpty(VideoPlayer.AudioCodec)</visible>
				</control>
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>[COLOR grey2]Audio: [/COLOR][COLOR grey2]No audio codec[/COLOR]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>String.IsEmpty(VideoPlayer.AudioCodec)</visible>
				</control>
				<!-- Sampling: only shown when not passthrough (passthrough gives 0-bit/0kHz) -->
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>[COLOR grey2]- sampling: [/COLOR]$INFO[Player.Process(audiobitspersample),,-bit] $VAR[|] $INFO[Player.Process(audio.sample.rate),, kHz]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>!Player.Passthrough</visible>
				</control>
				<!-- Audio language -->
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>[COLOR grey2]- language: [/COLOR]$VAR[AudioLanguagePlayVar] $VAR[|] $INFO[VideoPlayer.AudioLanguageEx]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + !String.IsEmpty(VideoPlayer.AudioLanguage)</visible>
				</control>
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>[COLOR grey2]- language: [/COLOR][COLOR grey2]Unknown[/COLOR]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + String.IsEmpty(VideoPlayer.AudioLanguage)</visible>
				</control>
				<!-- Audio layout -->
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>[COLOR grey2]- layout: [/COLOR]$VAR[AudioLayoutVar]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>!String.IsEmpty(VideoPlayer.AudioChannels)</visible>
				</control>
				<!-- Audio output -->
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>[COLOR grey2]- output: [/COLOR]Passthrough</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.Passthrough</visible>
				</control>
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>[COLOR grey2]- output: [/COLOR]$INFO[Player.Process(audiochannelssink),]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>!Player.Passthrough + !String.IsEmpty(Player.Process(audiochannelssink))</visible>
				</control>
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>[COLOR grey2]- output: [/COLOR]Decoding $VAR[|] [UPPERCASE]$INFO[Player.Process(audiodecoder)][/UPPERCASE]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>!Player.Passthrough + String.IsEmpty(Player.Process(audiochannelssink))</visible>
				</control>
				<!-- Audio bitrate -->
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>[COLOR grey2]- bitrate: [/COLOR]$INFO[Player.Process(audio.live.kibit.rate),, Kb/s] $INFO[VideoPlayer.AudioKibitRate,[COLOR grey2](, Kb/s)[/COLOR]]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
				</control>
				<!-- Subtitle: active and enabled -->
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>[COLOR grey2]Subtitle: [/COLOR]$INFO[VideoPlayer.SubtitlesLanguage,, [COLOR ff404040]|[/COLOR] ]$VAR[SubtitleVar]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + VideoPlayer.HasSubtitles + VideoPlayer.SubtitlesEnabled</visible>
				</control>
				<!-- Subtitle: present but disabled - whole value in grey, no colour suffix -->
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>[COLOR grey2]Subtitle: $INFO[VideoPlayer.SubtitlesLanguage,, | ]$VAR[SubtitleVar][/COLOR]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + VideoPlayer.HasSubtitles + !VideoPlayer.SubtitlesEnabled</visible>
				</control>
				<!-- Subtitle: none -->
				<control type="label">
					<width>580</width>
					<height>38</height>
					<label>[COLOR grey2]Subtitle: No subtitle[/COLOR]</label>
					<font>font12</font>
					<shadowcolor>black</shadowcolor>
					<visible>Player.HasVideo + !VideoPlayer.HasSubtitles</visible>
				</control>
			</control>

